{
  "name": "opentelemetry-esbuild-plugin-node",
  "description": "Esbuild plugin which bundles opentelemetry node core and contrib instrumentations into your code",
  "version": "4.5.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DrewCorlin/opentelemetry-node-bundler-plugins.git",
    "directory": "packages/opentelemetry-esbuild-plugin-node"
  },
  "keywords": [
    "opentelemetry",
    "bundler",
    "esbuild"
  ],
  "nx": {
    "targets": {
      "clean": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/opentelemetry-esbuild-plugin-node",
          "command": "rm -rf dist"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/opentelemetry-esbuild-plugin-node",
          "command": "tsdown"
        }
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.200.0",
    "@types/node": "^22.14.1",
    "@types/semver": "^7.7.0",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "opentelemetry-node-bundler-plugin-utils": "0.8.0"
  },
  "peerDependencies": {
    "esbuild": ">=0.19.x"
  }
}
