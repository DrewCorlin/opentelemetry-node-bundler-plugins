{
  "name": "opentelemetry-unplugin-node",
  "description": "Unplugin plugin which bundles opentelemetry node core and contrib instrumentations into your code",
  "version": "4.5.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DrewCorlin/opentelemetry-node-bundler-plugins.git",
    "directory": "packages/opentelemetry-unplugin-node"
  },
  "keywords": [
    "opentelemetry",
    "bundler",
    "unplugin",
    "vite",
    "rollup",
    "rolldown",
    "webpack",
    "esbuild"
  ],
  "nx": {
    "targets": {
      "clean": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/opentelemetry-unplugin-node",
          "command": "rm -rf dist"
        }
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "opentelemetry-node-bundler-plugin-utils": "0.8.0",
    "tslib": "^2.3.0",
    "unplugin": "^3.0.0"
  }
}
